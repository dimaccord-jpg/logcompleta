# --- CONFIGURACOES GERAIS ---
# Este arquivo e APENAS EXEMPLO (versionado, sem segredos reais). Copie para:
#   app/.env.dev      (desenvolvimento local)
#   app/.env.homolog  (homologacao)
#   app/.env.prod     (producao)
# e ajuste os VALORES. Nao use .env.example como fonte de execucao.
#
# APP_ENV (valores aceitos: dev | homolog | prod)
# - Obrigatorio no PROCESSO antes do import de app.settings (PowerShell: $env:APP_ENV="dev";
#   bash: export APP_ENV=dev; systemd/Render: variavel no servico).
# - Checagem na mesma sessao ANTES de python/gunicorn (se sair vazio, o boot falhara):
#     PowerShell: echo $env:APP_ENV
#     Bash:       echo $APP_ENV
# - app/settings.py le APP_ENV somente de os.environ; se estiver vazio, o boot falha (RuntimeError).
#   A linha APP_ENV abaixo documenta o arquivo-alvo; ela NAO substitui exportar APP_ENV no ambiente,
#   porque o arquivo .env.{APP_ENV} so e carregado DEPOIS que APP_ENV ja foi validado.
# - Excecao: migracoes Alembic (migrations/env.py) podem definir APP_ENV=dev se ausente — nao use
#   isso como desculpa para omitir APP_ENV no servico web ou nos scripts de aplicacao.
#
# Carregamento do restante das variaveis:
# - app/env_loader.load_app_env() carrega somente app/.env.{APP_ENV} (caminho absoluto; nao depende do CWD).
# - load_dotenv(override=False): variaveis ja definidas no ambiente NAO sao sobrescritas pelo arquivo.
#
# UX/Contraste: nao ha variavel de ambiente para tema de leitura. Ajustes visuais na View/CSS.

APP_ENV=dev
FLASK_DEBUG=True
SECRET_KEY=troque_por_uma_chave_forte_e_unica_por_ambiente
LOG_LEVEL=INFO
# URL pública opcional da página de planos por ambiente.
# Se vazio, o sistema tenta resolver automaticamente a rota real `/contrate-um-plano`
# usando o host atual da aplicação, evitando fallback indevido para localhost em homolog/prod.
# Exemplos:
# - dev:     http://127.0.0.1:5000/contrate-um-plano
# - homolog: https://homolog0514.agentefrete.com.br/contrate-um-plano
# - prod:    https://agentefrete.com.br/contrate-um-plano
PLANOS_UPGRADE_URL=

# --- STRIPE (FASE 2 - checkout embedded + webhook oficial) ---
# Stripe segue como fonte de fatos externos (nao substitui Franquia como fonte operacional).
# Chaves e segredo devem ser configurados por ambiente para habilitar contratacao.
# Homologacao Stripe so e considerada valida com as 3 variaveis abaixo preenchidas no ambiente-alvo
# e webhook `/api/webhook/stripe` recebendo evento assinado com sucesso.
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Opcional: URL base da API Stripe (default oficial).
# STRIPE_CHECKOUT_API_BASE_URL=https://api.stripe.com/v1
# URLs de retorno no fluxo de checkout embedded (podem ser relativas ou absolutas).
STRIPE_SUCCESS_URL=/contrate-um-plano?checkout=success
STRIPE_CANCEL_URL=/contrate-um-plano?checkout=cancelled

# --- BANCO DE DADOS E DIRETORIO DE DADOS (app/env_loader.py, app/infra.py, app/settings.py) ---
# Banco unico PostgreSQL por ambiente. Contrato canônico: DATABASE_URL (PostgreSQL obrigatorio).
# Sem SQLite nem outro SGBD para esses fluxos.
#
# Versao do PostgreSQL (contexto operacional validado neste projeto):
# - Homologacao e producao: PostgreSQL 16 (host gerenciado ou servidor).
# - Dev local (estado atual validado na equipe): o banco de trabalho correto estava no PostgreSQL 18;
#   homolog/prod continuam em 16 — nao confunda "mesmo nome de banco" com "mesma instancia".
#
# Risco: varios clusters PostgreSQL no mesmo Windows podem disputar a porta 5432. Quem estiver ATIVO
# nessa porta e quem recebe conexoes localhost:5432 — nao e o nome do database na URI que decide isso.
# Se conectar ao cluster errado, pode ver "banco vazio" ou tabelas ausentes (sem ser perda de dados no
# cluster correto). Valide servico, porta e instancia antes de culpar credencial.
#
# Ajuste usuario, senha, host, porta e nome do banco na URI abaixo.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@localhost:5432/logcompleta_dev
#
# Roberto BI / upload de planilha (.xlsx): nao exige variaveis extras. Localidades vêm de
# base_localidades neste mesmo PostgreSQL (sem DB separado). O upload resolve chaves em lote
# (uma query com chave_busca IN (...); mapa em memoria no processamento) — ver app/upload_handler.py
# e carregar_localidades_por_chaves em app/infra.py. O payload bruto do upload nao fica inteiro
# na sessao HTTP: a sessao guarda apenas referencia leve e os dados ficam em persistencia
# temporaria dedicada dentro de APP_DATA_DIR/roberto_upload_tmp, com TTL operacional.
#
# Alteracoes de schema: use Alembic/Flask-Migrate contra o mesmo PostgreSQL (DATABASE_URL).
#
# DEV (Local): pode usar caminhos relativos em APP_DATA_DIR (serao resolvidos para dentro da pasta do app).
# HOMOLOG/PROD (Render/servidores): precisam de caminho persistente FORA da pasta da release
# (ex.: /srv/seuapp/data/..., /var/data). Em homolog/prod, se nenhum diretorio persistente
# estiver configurado e gravavel, a aplicacao falhara no boot com erro explicito.
#
# Diretório de dados padrão (persistente):
# - Em dev, se vazio, o sistema pode cair para app/.
# - Em homolog/prod, deve apontar para volume persistente (ex.: /srv/logcompleta/data ou /var/data).
#   Se APP_DATA_DIR/RENDER_DISK_PATH/PERSISTENT_DATA_DIR/RENDER_DISK_MOUNT_PATH nao forem validos,
#   o boot e interrompido para evitar uso de filesystem efemero.
APP_DATA_DIR=

# --- E-MAIL (Recuperacao de senha / Esqueci minha senha) ---
# Envio realizado via Resend API (https://resend.com/).
# MAIL_USERNAME continua sendo usado apenas para bootstrap/admin (ver app/infra.py e app/auth_services.py),
# não para autenticação SMTP.
MAIL_USERNAME=admin@agentefrete.com.br
MAIL_DEFAULT_SENDER=noreply@agentefrete.com.br
MAIL_FROM=noreply@agentefrete.com.br
RESEND_API_KEY=sua_resend_api_key_aqui

# --- LOGIN SOCIAL (Google) ---
# Crie credenciais em: https://console.cloud.google.com/apis/credentials
# URIs de redirecionamento autorizados: use o mesmo valor de GOOGLE_OAUTH_REDIRECT_URI
GOOGLE_OAUTH_CLIENT_ID=seu_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=seu_google_oauth_client_secret
# URI de callback (dev: http://127.0.0.1:5000/login/google/callback; homolog/prod: https://seu-dominio/login/google/callback)
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/login/google/callback

# --- CHAVES DE API (AGENTES) ---
# GEMINI_API_KEY: chave exclusiva do Cleiton (run_cleiton.py)
GEMINI_API_KEY=sua_chave_aqui

# GEMINI_API_KEY_1: Julia - noticias rapidas
GEMINI_API_KEY_1=sua_chave_aqui

# GEMINI_API_KEY_2: Julia - artigos estrategicos
GEMINI_API_KEY_2=sua_chave_aqui

# Modelo textual preferencial da Julia (run_julia_agente_redacao).
# Fallback automático: gemini-2.5-flash, gemini-1.5-flash.
GEMINI_MODEL_TEXT=gemini-2.5-flash
# Timeout HTTP das chamadas Gemini de texto (ms).
# Em homolog/prod, use valor conservador para evitar travar worker em chamadas externas.
GEMINI_HTTP_TIMEOUT_MS=20000

# --- IMAGEM IA (run_julia_agente_imagem) ---
# IMAGE_PROVIDER: auto | gemini | placeholder | fallback
# gemini (recomendado para qualidade): prioriza Gemini Imagen; se necessario,
# usa fallback Gemini multimodal para bytes de imagem e salva em /static/generated.
# auto: mesmo fluxo do gemini e, se falhar, aplica fallback contextual de stock salvo localmente.
# GEMINI_MODEL_IMAGE: modelo Imagen principal (ex.: imagen-3.0-generate-002)
# GEMINI_MODEL_IMAGE_FALLBACK: modelo Gemini multimodal opcional para extrair bytes de imagem.
# IMAGE_RETRY_ATTEMPTS / IMAGE_RETRY_BACKOFF_MS: retentativas para chamadas Gemini de imagem.
# IMAGE_STOCK_FALLBACK_ENABLED: habilita fallback fotografico contextual salvo em /static/generated/julia_stock_<hash>.jpg.
# IMAGEM_FALLBACK_URL: opcional. Se definido, tem prioridade como fallback final (ex.: CDN propria).
# Se vazio e sem stock disponivel, usa asset local versionado: /static/img/fallback-capa-v1.svg
# IMAGE_ALLOW_REMOTE_FALLBACK: por padrao false. true habilita fallback remoto (loremflickr/placehold) apenas em ultimo caso.
IMAGE_PROVIDER=gemini
GEMINI_MODEL_IMAGE=imagen-3.0-generate-002
# GEMINI_MODEL_IMAGE_FALLBACK=gemini-2.5-flash-image-preview
# Timeout HTTP das chamadas Gemini de imagem (ms). Se ausente, usa GEMINI_HTTP_TIMEOUT_MS.
GEMINI_IMAGE_HTTP_TIMEOUT_MS=20000
# IMAGE_RETRY_ATTEMPTS=3
# IMAGE_RETRY_BACKOFF_MS=800
# IMAGE_STOCK_FALLBACK_ENABLED=true
# IMAGE_ALLOW_REMOTE_FALLBACK=false
# IMAGEM_FALLBACK_URL=https://sua-cdn.com/imagens/fallback-logistica.jpg

# Avatar da editora exibido em /noticia/<id> (opcional).
# Se vazio, usa o asset local app/static/img/julia-avatar.svg.
# JULIA_AVATAR_URL=https://sua-cdn.com/imagens/julia.jpg
#ROBERTO_AVATAR_URL=/static/img/roberto-avatar.svg

# GEMINI_API_KEY_ROBERTO: Roberto - analises de frete
GEMINI_API_KEY_ROBERTO=sua_chave_aqui

# Modelo preferencial do Roberto (fallback automático: GEMINI_MODEL_TEXT, gemini-2.5-flash, gemini-1.5-flash)
GEMINI_MODEL_FRETE=gemini-2.5-flash

# --- FASE 1: MEDIÇÃO GERENCIAL IA + CUSTO GCP (BigQuery billing export) ---
# Tabela do export de billing no BigQuery: projeto.dataset.tabela (ex.: gcp_billing_export_v1_*).
# Requer credenciais com leitura (GOOGLE_APPLICATION_CREDENTIALS ou workload identity).
# Consulta interna: SUM(cost) no mês corrente (usage_start_time). Ajuste a tabela no console GCP se o nome divergir.
# GCP_BILLING_EXPORT_TABLE=meu-projeto.billing_export.gcp_billing_export_resource_v1_XXXXX
#
# Cron: agendar GET ou POST /cron/billing-snapshot com X-Cron-Secret (mesmo CRON_SECRET), ~4x/dia.

# --- OPCAO DE DESENVOLVIMENTO (LOCAL) ---
# O app so permite OAuth em HTTP quando esta variavel estiver definida (1/true).
# Em .env.dev: descomente a linha abaixo para login Google em http://127.0.0.1:5000.
# Em .env.homolog e .env.prod: NAO defina (ou use 0) para exigir HTTPS.
# OAUTHLIB_INSECURE_TRANSPORT=1

# --- FASE 3: SCOUT + VERIFICADOR (run_cleiton_agente_scout / run_cleiton_agente_verificador) ---
# Scout: coleta de pautas (RSS/API). Verificador: score e status (aprovado/revisar/rejeitado). So aprovadas va para Julia.
# SCOUT_ENABLED=true|false (default true)
SCOUT_ENABLED=true
# SCOUT_SOURCES_JSON: array JSON em uma única linha.
# IMPORTANTE:
# - Nao use multilinha.
# - Nao inclua comentarios dentro do JSON.
# - Nao use espacos ao redor do '=' para evitar interpretacoes inesperadas no parser.
# - Fonte RSS: {"url":"https://...", "tipo":"noticia", "tipo_fonte":"rss"}
# - Google Alerts: {"url":"https://www.google.com/alerts/feeds/...", "tipo":"noticia", "tipo_fonte":"google_alerts_rss"}
# Exemplo com múltiplas fontes:
# SCOUT_SOURCES_JSON=[{"url":"https://g1.globo.com/rss/g1/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://news.google.com/rss/search?q=logistica&hl=pt-BR&gl=BR&ceid=BR:pt-419","tipo":"noticia","tipo_fonte":"rss"}]
# Exemplo completo (copiar e colar em uma única linha):
# SCOUT_SOURCES_JSON=[{"url":"https://news.google.com/rss/search?q=logistica&hl=pt-BR&gl=BR&ceid=BR:pt-419","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://news.google.com/rss/search?q=frete+transporte+logistica&hl=pt-BR&gl=BR&ceid=BR:pt-419","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://g1.globo.com/rss/g1/economia/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.portosenavios.com.br/rss.xml","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.tecnologistica.com.br/portal/rss","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://logweb.com.br/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.mundologistica.com.br/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.guiadotrc.com.br/noticias/rss.asp","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.transportemoderno.com.br/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.canalrural.com.br/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.agenciainfra.com/blog/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://valor.globo.com/rss/empresas.xml","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.istoedinheiro.com.br/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.supplychaindive.com/feeds/news/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.supplychainbrain.com/rss","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.logisticsmgmt.com/rss.xml","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.joc.com/rss","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.freightwaves.com/feed","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.aircargonews.net/rss","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.maritime-executive.com/rss","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.transporttopics.com/rss","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.globaltrademag.com/feed/","tipo":"noticia","tipo_fonte":"rss"},{"url":"https://www.dcvelocity.com/rss","tipo":"noticia","tipo_fonte":"rss"}]
SCOUT_MAX_ITENS_POR_CICLO=20
# Timeout HTTP do Scout para fontes RSS/API (segundos).
SCOUT_HTTP_TIMEOUT_SECONDS=10
# Verificador: score 0.0 a 1.0; minimo para aprovado
VERIFICADOR_SCORE_MINIMO=0.5
# Lista de dominios confiaveis (virgula). Se vazio, nao aplica reducao por fonte.
# O match de dominio e exato (ex.: valor.globo.com e diferente de globo.com).
# VERIFICADOR_FONTES_CONFIAVEIS=valor.globo.com,g1.globo.com,transportemoderno.com.br,logweb.com.br,portosenavios.com.br,tecnologistica.com.br,supplychaindive.com,supplychainbrain.com,logisticsmgmt.com,freightwaves.com
# Dominios bloqueados (virgula). Se presente, rejeita direto.
# VERIFICADOR_BLOQUEAR_DOMINIOS=example-spam.com,agregador-ruido.net,dominio-suspeito.xyz
# Limiar de similaridade de titulo (0-1). Acima = duplicidade semantica (revisar/rejeitar)
VERIFICADOR_SIMILARIDADE_TITULO=0.85
# Quantidade maxima de registros historicos analisados para similaridade semantica.
VERIFICADOR_MAX_REGISTROS_SIMILARIDADE=500
# Termos de relevancia simples para noticias de logistica/supply chain/frete/etc. (separados por virgula).
# Usados pelo Verificador para atribuir um pequeno bonus de score quando presentes no titulo/fonte.
VERIFICADOR_TERMOS_RELEVANTES=logistica,logístico,logística,frete,fretes,supply chain,supply-chain,cadeia de suprimentos,transportes,roteirizacao,ultima milha,última milha
# Limites de recencia em horas: noticias coletadas dentro da janela "quente" recebem bonus;
# alem da janela "aceitavel" perdem peso de score.
VERIFICADOR_RECENCIA_HORAS_QUENTE=24
VERIFICADOR_RECENCIA_HORAS_ACEITAVEL=72
# Pipeline Julia: status do Verificador aceitos para processamento.
# Padrão recomendado em produção: apenas aprovado.
# Em homolog (recomendado para acelerar entrada de notícias enquanto calibra fontes): aprovado,revisar
# Observação operacional: o Scout pode reativar pautas com status "falha" quando o mesmo link reaparece
# (desde que não exista publicação em noticias_portal), evitando bloqueio eterno por duplicata.
JULIA_STATUS_VERIFICACAO_PERMITIDOS=aprovado

# --- FASE 4: DESIGNER + PUBLISHER (run_julia_agente_designer / run_julia_agente_publisher) ---
# Designer: asset visual por canal (url_imagem_master, assets_por_canal). Publisher: publicacao portal + canais.
DESIGNER_ENABLED=true
DESIGNER_PROVIDER=fallback
DESIGNER_ASPECT_RATIO_PADRAO=16:9
DESIGNER_CANAIS_ATIVOS=portal,linkedin,instagram,email
PUBLISHER_ENABLED=true
PUBLISHER_CANAIS_ATIVOS=portal,linkedin,instagram,email
PUBLISHER_MODO=mock
PUBLISHER_MAX_TENTATIVAS=3
# PUBLISHER_INTERVALO_MINUTOS_ENTRE_POSTS=15
# PUBLISHER_JANELA_PUBLICACAO_INICIO=6
# PUBLISHER_JANELA_PUBLICACAO_FIM=22

# --- FASE 5: CUSTOMER INSIGHT (run_cleiton_agente_customer_insight / run_julia_agente_metricas) ---
# Mede desempenho por conteudo/canal; gera recomendacoes estrategicas para o Cleiton.
INSIGHT_ENABLED=true
# INSIGHT_COLETA_MODO=mock|real (mock = metricas estimadas; real = futuro API)
INSIGHT_COLETA_MODO=mock
# Janela em dias para coleta e analise de metricas
INSIGHT_JANELA_DIAS=30
# Score acima deste valor => classificacao escalar; abaixo de INSIGHT_SCORE_PAUSAR => pausar
INSIGHT_SCORE_ESCALAR=70
INSIGHT_SCORE_PAUSAR=25
# Abaixo deste numero de impressoes => considerar pausar
INSIGHT_MIN_IMPRESSOES=100

# --- ROTAS DE OPERACAO (app/ops_routes.py) ---
# Token para /oauth-diagnostics, /ops/user-audit, /ops/promote-admin. /health nao exige token.
# Envie no header: X-Ops-Token: <valor>. Gere um valor secreto (ex.: openssl rand -hex 32).
OPS_TOKEN=troque_por_token_secreto

# --- EXECUCAO MANUAL CLEITON NO PAINEL ADMIN ---
# Modo do botão /admin/agentes/julia/executar-cleiton
# - Em homolog/prod, padrão é async (não bloqueia requisição HTTP)
# - Em dev, padrão é sync (feedback detalhado na própria resposta)
# Opcional: forçar manualmente com ADMIN_CLEITON_EXEC_MODE=sync|async
# ADMIN_CLEITON_EXEC_MODE=async

# --- GUNICORN (homolog/prod) ---
# Timeouts do worker para requisições que dependem de I/O externo.
# Ajuste no ambiente do serviço (Render/Systemd) conforme necessidade.
GUNICORN_TIMEOUT_SECONDS=120
GUNICORN_GRACEFUL_TIMEOUT_SECONDS=30
GUNICORN_KEEPALIVE_SECONDS=5

# --- CRON (execucao automatica do ciclo Cleiton em homolog/prod) ---
# Usado pela rota /cron/executar-cleiton (Render Cron Job ou outro agendador).
# Gere um valor secreto (ex.: openssl rand -hex 32). Envie no header X-Cron-Secret ou em ?secret=<valor>.
# Em homolog/prod, este valor **não pode ficar vazio**: se `CRON_SECRET` estiver em branco,
# a rota sempre respondera 403 (nao autorizada) e o Cron Job nao conseguira executar o ciclo.
# Padrao operacional no Render: usar `curl -fsS` com header `X-Cron-Secret` e nao depender de `?secret=`.
# Compatibilidade temporaria: a query string ainda existe neste momento, mas sera removida apos a homologacao.
# Variaveis necessarias no Cron Job:
#   APP_BASE_URL=https://seu-servico.onrender.com
#   CRON_SECRET=<mesmo valor configurado no web service>
# Comandos padrao:
#   curl -fsS -X POST "$APP_BASE_URL/cron/executar-cleiton" -H "X-Cron-Secret: $CRON_SECRET"
#   curl -fsS -X POST "$APP_BASE_URL/cron/billing-snapshot" -H "X-Cron-Secret: $CRON_SECRET"
# Validacao esperada:
#   sem header -> 403
#   header invalido -> 403
#   header correto -> 200 / execucao da rotina
#   `curl -f` torna falhas 4xx/5xx visiveis no Render
CRON_SECRET=

# --- COLETA DE INDICES DA HOME (Petróleo, BDI, FBX, Dólar) ---
# A coleta roda por comando dedicado (python -m app.finance) em job do agendador
# e atualiza o arquivo apontado por INDICES_FILE_PATH no formato historico.
# Em homolog/prod, configure INDICES_FILE_PATH para um caminho persistente fora da pasta app.
# No Render, recomendacao: montar disco persistente em /var/data e usar:
#   APP_DATA_DIR=/var/data
#   INDICES_FILE_PATH=/var/data/indices.json
# Em dev, se vazio, o sistema usa app/indices.json.
# Em homolog/prod, se INDICES_FILE_PATH for invalido ou apontar para a pasta da release,
# app/env_loader.validate_runtime_env interrompera o boot com erro explicito.
INDICES_FILE_PATH=

# --- ADMIN (quem tem privilegio admin) ---
# E-mail promovido a admin no primeiro login (opcional). Usado tambem pelo auth_services para OAuth.
BOOTSTRAP_ADMIN_EMAIL=admin@seu-dominio.com
# Lista de e-mails com acesso admin (separados por virgula). auth_services usa ao criar/atualizar usuario OAuth.
# ADMIN_EMAILS=admin1@exemplo.com,admin2@exemplo.com

# --- LOGS DE IMPORTACAO (admin/processar_importacao) ---
# Diretorio base para arquivos sucesso_*.txt e erro_*.txt em importacoes do painel admin.
# Se ausente, usa fallback local em logs_fallback.
# LOG_DIR=./logs
