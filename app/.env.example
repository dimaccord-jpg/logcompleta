# --- CONFIGURAÇÕES GERAIS ---
# Opções: dev, homolog, prod
APP_ENV=dev
FLASK_DEBUG=True
SECRET_KEY=troque_isso_em_producao
LOG_LEVEL=INFO

# --- BANCO DE DADOS ---
# DEV/HOMOLOG (Local): Use caminhos relativos ou absolutos locais
# PROD (Servidor): Use caminhos absolutos persistentes (ex: /srv/seuapp/data/...)
# Exemplo Prod: sqlite:////srv/logcompleta/data/auth.db

DB_URI_AUTH=sqlite:///painel_admin/auth.db
DB_URI_LOCALIDADES=sqlite:///base_localidades.db
DB_URI_HISTORICO=sqlite:///historico_frete.db
DB_URI_LEADS=sqlite:///leads.db
DB_URI_NOTICIAS=sqlite:///noticias.db

