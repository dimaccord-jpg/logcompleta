# --- CONFIGURACOES GERAIS ---
# Copie este arquivo para .env.dev, .env.homolog e .env.prod
# e ajuste apenas os VALORES (nao altere os nomes das variaveis).
# Opcoes de APP_ENV: dev, homolog, prod

APP_ENV=dev
FLASK_DEBUG=True
SECRET_KEY=troque_por_uma_chave_forte_e_unica_por_ambiente
LOG_LEVEL=INFO

# --- BANCO DE DADOS (app/infra.py: resolve_sqlite_path, ensure_database_schema) ---
# Apos alteracoes no modelo User (ex.: login Google), se auth.db ja existia, apague
# app/painel_admin/auth.db para recriar as tabelas ao subir a aplicacao.
# DEV/HOMOLOG (Local): Use caminhos relativos ou absolutos locais
# PROD (Servidor): Use caminhos absolutos persistentes (ex: /srv/seuapp/data/...)
# Exemplo Prod: sqlite:////srv/logcompleta/data/auth.db

DB_URI_AUTH=sqlite:///painel_admin/auth.db
DB_URI_LOCALIDADES=sqlite:///base_localidades.db
DB_URI_HISTORICO=sqlite:///historico_frete.db
DB_URI_LEADS=sqlite:///leads.db
DB_URI_NOTICIAS=sqlite:///noticias.db

# --- E-MAIL (Recuperacao de senha / Esqueci minha senha) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_DEFAULT_SENDER=seu_email@gmail.com

# --- LOGIN SOCIAL (Google) ---
# Crie credenciais em: https://console.cloud.google.com/apis/credentials
# URIs de redirecionamento autorizados: use o mesmo valor de GOOGLE_OAUTH_REDIRECT_URI
GOOGLE_OAUTH_CLIENT_ID=seu_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=seu_google_oauth_client_secret
# URI de callback (dev: http://127.0.0.1:5000/login/google/callback; homolog/prod: https://seu-dominio/login/google/callback)
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:5000/login/google/callback

# --- CHAVES DE API (AGENTES) ---
# GEMINI_API_KEY: chave exclusiva do Cleiton (run_cleiton.py)
GEMINI_API_KEY=sua_chave_aqui

# GEMINI_API_KEY_1: Julia - noticias rapidas
GEMINI_API_KEY_1=sua_chave_aqui

# GEMINI_API_KEY_2: Julia - artigos estrategicos
GEMINI_API_KEY_2=sua_chave_aqui

# GEMINI_API_KEY_ROBERTO: Roberto - analises de frete
GEMINI_API_KEY_ROBERTO=sua_chave_aqui

# --- OPCAO DE DESENVOLVIMENTO (LOCAL) ---
# O app so permite OAuth em HTTP quando esta variavel estiver definida (1/true).
# Em .env.dev: descomente a linha abaixo para login Google em http://127.0.0.1:5000.
# Em .env.homolog e .env.prod: NAO defina (ou use 0) para exigir HTTPS.
# OAUTHLIB_INSECURE_TRANSPORT=1

# --- ROTAS DE OPERACAO (app/ops_routes.py) ---
# Token para /oauth-diagnostics, /ops/user-audit, /ops/promote-admin. /health nao exige token.
# Envie no header: X-Ops-Token: <valor>. Gere um valor secreto (ex.: openssl rand -hex 32).
OPS_TOKEN=troque_por_token_secreto

# --- ADMIN (quem tem privilegio admin) ---
# E-mail promovido a admin no primeiro login (opcional). Usado tambem pelo auth_services para OAuth.
BOOTSTRAP_ADMIN_EMAIL=admin@seu-dominio.com
# Lista de e-mails com acesso admin (separados por virgula). auth_services usa ao criar/atualizar usuario OAuth.
# ADMIN_EMAILS=admin1@exemplo.com,admin2@exemplo.com